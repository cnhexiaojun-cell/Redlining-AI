# Server
# SERVER_PORT=8003

# Database (or set spring.datasource.url directly)
# DATABASE_URL=jdbc:mysql://127.0.0.1:3306/redlining?useUnicode=true&characterEncoding=utf8
# DATABASE_USERNAME=redlining
# DATABASE_PASSWORD=redlining

# JWT
# JWT_SECRET=your-random-secret-at-least-32-chars
# JWT_EXPIRE_MINUTES=60

# LLM provider: deepseek | zhipu | modelscope
# LLM_PROVIDER=deepseek

# DeepSeek (default)
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-chat

# 智谱 GLM（设置 LLM_PROVIDER=zhipu 并填写 ZHIPU_API_KEY）
# ZHIPU_API_KEY=your_zhipu_api_key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL_NAME=glm-4-flash

# Or ModelScope
# MODELSCOPE_API_KEY=your_api_key_here
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# Redis (optional; cache disabled if unavailable)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# CACHE_ANALYSIS_TTL=3600
